# =========================
# OpenRecall .env 示例配置
# =========================

# --- API / 模型 ---
OPENRECALL_API_KEY=default
OPENRECALL_API_URL=http://127.0.0.1:1234/v1/chat/completions
OPENRECALL_MODEL=default
SCREEN_ANALYSIS_PROMPT=请描述这张截图中用户正在使用什么软件，在做什么，并进行分类，严格按照格式输出结果：【类型】【软件】【主要工作摘要】。
API_TIMEOUT_SECONDS=120

# --- 截屏服务 ---
SCREENSHOT_INTERVAL_SECONDS=30
START_CAPTURE_ON_LAUNCH=true
KEEP_SCREENSHOTS=false
INSTALLED_APPS_ENABLED=true
INSTALLED_APPS_REFRESH_MINUTES=30
INSTALLED_APPS_MAX_ITEMS=300
INSTALLED_APPS_INCLUDE_USER_DIR=true
INPUT_CONTEXT_ENABLED=false
INPUT_CONTEXT_WINDOW_SECONDS=60
INPUT_CONTEXT_MAX_KEYSTROKES=120
INPUT_CONTEXT_INCLUDE_RAW_KEYS=true

# --- 数据路径（可选，不填使用系统默认目录） ---
# SCREENTIME_DATA_DIR=/path/to/openrecall-data
# SERVICE_STATE_PATH=/path/to/service_state.json
# SERVICE_SOCKET_PATH=/path/to/service.sock
# TEST_LOG_PATH=test_log.json

# --- 图片处理 ---
IMAGE_TARGET_WIDTH=1440
IMAGE_GRAYSCALE=true

# --- MCP ---
MCP_PORT=6672
# Windows 下控制端口（Unix 下走 socket）
SERVICE_CONTROL_PORT=5830

# --- 剪贴板监听 ---
CLIPBOARD_ENABLED=true
CLIPBOARD_INTERVAL_MS=500
CLIPBOARD_AUTO_SAVE=true
CLIPBOARD_NOTIFY_ON_SAVE=true
CLIPBOARD_AI_FILTER_ENABLED=true
CLIPBOARD_AI_FILTER_PROMPT=你是剪贴板内容过滤器。任务：判断该内容是否应保存，用于后续 web-search 研究。判定原则：1) 包含可研究 URL 时 save=true；2) 可检索关键词组合/代号组合/项目标识（即使较短）时 save=true，例如“YC 2006 W26项目汇总”；3) 明确研究主题、问题描述、技术路线时 save=true。若为验证码、密码、token、私钥、cookie、账号等敏感信息或无意义噪音则 save=false。只输出一行JSON：{"save":true|false,"reason":"不超过20字","category":"url|keyword_combo|topic|noise|sensitive"}。
CLIPBOARD_AI_MIN_CHARS=6
CLIPBOARD_AI_TIMEOUT_SECONDS=10
CLIPBOARD_AI_SAVE_ON_ERROR=false
# CLIPBOARD_TARGET_DIR=/path/to/clipboard/exports
CLIPBOARD_MAX_BYTES=200000

# --- OpenClaw（可选，URL 和 TOKEN 同时设置才生效） ---
# OPENCLAW_URL=http://127.0.0.1:18789/hooks/agent
# OPENCLAW_TOKEN=your_webhook_token
OPENCLAW_REPORT_INTERVAL_MINUTES=30